{
  "name": "reorg-safe-indexer",
  "version": "0.1.0",
  "description": "Lightweight, configurable blockchain event indexer with built-in chain reorganization handling. Idempotent processing, automatic rollback on reorgs, pluggable storage backends.",
  "keywords": [
    "ethereum",
    "evm",
    "indexer",
    "events",
    "logs",
    "reorg",
    "reorganization",
    "ethers",
    "blockchain",
    "web3"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0",
    "ethers": "^6.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vitest/coverage-v8": "^1.4.0",
    "better-sqlite3": "^11.0.0",
    "eslint": "^8.57.0",
    "ethers": "^6.11.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChainPrimitives/reorg-safe-indexer.git"
  },
  "homepage": "https://github.com/ChainPrimitives/reorg-safe-indexer#readme",
  "bugs": {
    "url": "https://github.com/ChainPrimitives/reorg-safe-indexer/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
